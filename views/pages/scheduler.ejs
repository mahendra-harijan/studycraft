<%- include('../partials/head') %>
<body class="scheduler-page">
  <%- include('../partials/navbar') %>
  <br><br><br>

  <!-- Page Header with Gradient -->
  <div class="page-header">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-8">
          <h1 class="page-title">
            <i class="fas fa-calendar-alt me-3"></i>
            Smart Class Scheduler
          </h1>
          <p class="page-subtitle">Organize your academic schedule with intelligent clash detection and weekly repeats</p>
        </div>
        <div class="col-lg-4 text-lg-end">
          <div class="header-stats">
            <div class="stat-item">
              <span class="stat-label">Total Classes</span>
              <span  class="stat-value" id="totalClassesCount">0</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">This Week</span>
              <span class="stat-value" id="weeklyClassesCount">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <main class="main-content">
    <div class="container">
      <!-- Alert Container -->
      <div id="alertContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 9999"></div>

      <!-- Add Class Card -->
      <div class="row mb-4">
        <div class="col-12">
          <div class="card add-class-card">
            <div class="card-header">
              <div class="d-flex align-items-center">
                <div class="header-icon">
                  <i class="fas fa-plus-circle"></i>
                </div>
                <div>
                  <h5 class="mb-0">Add New Class</h5>
                  <small class="text-muted">Fill in the details to schedule a new class</small>
                </div>
              </div>
            </div>
            <div class="card-body">
              <form id="scheduleForm" class="needs-validation" novalidate>
                <div class="row g-4">
                  <!-- Subject Input -->
                  <div class="col-md-6">
                    <div class="form-group">
                      <label for="subject" class="form-label">
                        <i class="fas fa-book me-2 text-primary"></i>Subject Name
                      </label>
                      <input type="text" class="form-control" id="subject" name="subject" 
                             placeholder="e.g., Advanced Mathematics" required maxlength="100">
                      <div class="invalid-feedback">Please enter a subject name</div>
                    </div>
                  </div>

                  <!-- Venue Input -->
                  <div class="col-md-6">
                    <div class="form-group">
                      <label for="venue" class="form-label">
                        <i class="fas fa-map-marker-alt me-2 text-primary"></i>Venue / Room
                      </label>
                      <input type="text" class="form-control" id="venue" name="venue" 
                             placeholder="e.g., Room 301, Lab 204" required maxlength="200">
                      <div class="invalid-feedback">Please enter a venue</div>
                    </div>
                  </div>

                  <!-- Day Select -->
                  <div class="col-md-4">
                    <div class="form-group">
                      <label for="day" class="form-label">
                        <i class="fas fa-calendar-day me-2 text-primary"></i>Day of Week
                      </label>
                      <select class="form-select" id="day" name="day" required>
                        <option value="" selected disabled>-- Select a day --</option>
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                        <option value="Saturday">Saturday</option>
                        <option value="Sunday">Sunday</option>
                      </select>
                      <div class="invalid-feedback">Please select a day</div>
                    </div>
                  </div>

                  <!-- Start Time -->
                  <div class="col-md-4">
                    <div class="form-group">
                      <label for="startTime" class="form-label">
                        <i class="fas fa-clock me-2 text-primary"></i>Start Time
                      </label>
                      <input type="time" class="form-control" id="startTime" name="startTime" required>
                      <div class="invalid-feedback">Please select start time</div>
                    </div>
                  </div>

                  <!-- End Time -->
                  <div class="col-md-4">
                    <div class="form-group">
                      <label for="endTime" class="form-label">
                        <i class="fas fa-clock me-2 text-primary"></i>End Time
                      </label>
                      <input type="time" class="form-control" id="endTime" name="endTime" required>
                      <div class="invalid-feedback">Please select end time</div>
                    </div>
                  </div>

                  <!-- Weekly Repeat Toggle -->
                  <div class="col-12">
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" id="weeklyRepeat" 
                             name="weeklyRepeat" checked style="width: 3rem; height: 1.5rem; cursor: pointer;">
                      <label class="form-check-label ms-2" for="weeklyRepeat" style="cursor: pointer;">
                        <strong>Weekly Repeat</strong>
                        <span class="d-block small text-muted">Class repeats every week automatically</span>
                      </label>
                    </div>
                  </div>

                  <!-- Submit Button -->
                  <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                      <i class="fas fa-plus-circle me-2"></i>
                      Add to Schedule
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-lg px-5 ms-2" 
                            onclick="resetForm()">
                      <i class="fas fa-undo-alt me-2"></i>
                      Reset
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>

      <!-- Schedule View -->
      <div class="row">
        <div class="col-12">
          <div class="card schedule-card">
            <div class="card-header">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                  <i class="fas fa-table me-2"></i>
                  Your Class Schedule
                </h5>
                <div class="schedule-filters">
                  <select class="form-select form-select-sm" id="dayFilter" style="width: auto;">
                    <option value="">All Days</option>
                    <option value="Monday">Monday</option>
                    <option value="Tuesday">Tuesday</option>
                    <option value="Wednesday">Wednesday</option>
                    <option value="Thursday">Thursday</option>
                    <option value="Friday">Friday</option>
                    <option value="Saturday">Saturday</option>
                    <option value="Sunday">Sunday</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table schedule-table">
                  <thead>
                    <tr>
                      <th>SUBJECT</th>
                      <th>DAY</th>
                      <th>START TIME</th>
                      <th>END TIME</th>
                      <th>VENUE</th>
                      <th>ACTION</th>
                    </tr>
                  </thead>
                  <tbody id="scheduleTableBody">
                    <tr>
                      <td colspan="6" class="text-center py-5">
                        <div class="empty-state">
                          <i class="fas fa-calendar-plus fa-3x mb-3 text-muted"></i>
                          <h6>No classes scheduled</h6>
                          <p class="text-muted">Add your first class using the form above</p>
                        </div>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
  <script src="/public/js/scheduler.js?v=20260225-5"></script>

  <style>
    /* Page Specific Styles */
    .scheduler-page {
      background: linear-gradient(135deg, #f5f7fa 0%, #e9ecf5 100%);
      min-height: 100vh;
    }

    body.dark-mode .scheduler-page {
      background: linear-gradient(135deg, #1a1c24 0%, #0f1117 100%);
    }

    /* Page Header */
    .page-header {
      background: linear-gradient(135deg, #4361ee 0%, #7209b7 100%);
      padding: 3rem 0;
      margin-bottom: 2rem;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.1"><path d="M10 50 Q 30 30, 50 50 T 90 50" stroke="white" fill="none" stroke-width="2"/><circle cx="20" cy="20" r="3" fill="white"/><circle cx="80" cy="80" r="3" fill="white"/></svg>');
      background-size: 100px 100px;
      opacity: 0.1;
    }

    .page-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
    }

    .page-subtitle {
      font-size: 1.1rem;
      opacity: 0.9;
      margin-bottom: 0;
    }

    .header-stats {
      display: flex;
      justify-content: center;   /* center items horizontally */
      align-items: center;       /* vertical alignment */
      gap: 2rem;
      background: rgba(255, 255, 255, 0.1);
      padding: 1rem 2rem;
      border-radius: 50px;
      backdrop-filter: blur(10px);

    }

    .stat-item {
      justify-items: center;
      text-align: center;
      
    }

    .stat-label {
      display: block;
      font-size: 0.8rem;
      opacity: 0.9;
      margin-bottom: 0.2rem;
      color: white;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 700;
      line-height: 1;
      color: white;
      justify-items: center;
      text-align: center;
      
    }

    /* Add Class Card */
    .add-class-card {
      border: none;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .add-class-card .card-header {
      background: linear-gradient(135deg, #f8f9fa, #ffffff);
      border-bottom: 1px solid #e9ecef;
      padding: 1.5rem;
    }

    body.dark-mode .add-class-card .card-header {
      background: linear-gradient(135deg, #2d2d3a, #252532);
      border-bottom-color: #3a3a4a;
    }

    .header-icon {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, #4361ee, #7209b7);
      border-radius: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 1rem;
    }

    .header-icon i {
      font-size: 1.8rem;
      color: white;
    }

    .add-class-card .card-body {
      padding: 2rem;
    }

    /* Form Styles */
    .form-group {
      margin-bottom: 1rem;
    }

    .form-group .form-label {
      font-weight: 500;
      color: #495057;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
    }

    body.dark-mode .form-group .form-label {
      color: #e0e0e0;
    }

    .form-group .form-control,
    .form-group .form-select {
      height: 48px;
      border-radius: 12px;
      border: 2px solid #e9ecef;
      padding: 0.5rem 1rem;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .form-group .form-control:focus,
    .form-group .form-select:focus {
      border-color: #4361ee;
      box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
      outline: none;
    }

    body.dark-mode .form-group .form-control,
    body.dark-mode .form-group .form-select {
      background: #2d2d3a;
      border-color: #3a3a4a;
      color: white;
    }

    .form-group .form-control::placeholder {
      color: #adb5bd;
      font-size: 0.95rem;
    }

    body.dark-mode .form-group .form-control::placeholder {
      color: #6c757d;
    }




    

    /* Form Switch */
    .form-check-input {
      cursor: pointer;
    }

    .form-check-input:checked {
      background-color: #4361ee;
      border-color: #4361ee;
    }

    .form-check-label {
      cursor: pointer;
    }

    /* Schedule Card */
    .schedule-card {
      border: none;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .schedule-card .card-header {
      background: white;
      border-bottom: 1px solid #e9ecef;
      padding: 1.5rem;
    }

    body.dark-mode .schedule-card .card-header {
      background: #2d2d3a;
      border-bottom-color: #3a3a4a;
    }

    /* Schedule Table */
    .schedule-table {
      margin-bottom: 0;
    }

    .schedule-table thead th {
      background: #f8f9fa;
      color: #495057;
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 1rem;
      text-align: left;
      white-space: nowrap;
    }

    body.dark-mode .schedule-table thead th {
      background: #252532;
      color: #e0e0e0;
    }

    .schedule-table tbody td {
      padding: 1rem;
      vertical-align: middle;
      text-align: left;
    }

    /* Time display formatting */
    .schedule-table tbody td:nth-child(3),
    .schedule-table tbody td:nth-child(4) {
      font-family: 'Courier New', monospace;
      font-weight: 500;
      white-space: nowrap;
    }

    /* Empty State */
    .empty-state {
      padding: 3rem;
      text-align: center;
    }

    .empty-state i {
      font-size: 4rem;
      color: #dee2e6;
    }

    .empty-state h6 {
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
      color: #495057;
    }

    body.dark-mode .empty-state h6 {
      color: #e0e0e0;
    }

    .empty-state p {
      color: #6c757d;
      font-size: 0.95rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .page-header {
        padding: 2rem 0;
      }

      .page-title {
        font-size: 1.8rem;
      }

      .header-stats {
        justify-content: center;
        margin-top: 1rem;
      }

      .add-class-card .card-body {
        padding: 1.5rem;
      }

      .schedule-table thead th {
        font-size: 0.8rem;
        padding: 0.8rem;
      }

      .schedule-table tbody td {
        padding: 0.8rem;
        font-size: 0.9rem;
      }

      .empty-state {
        padding: 2rem;
      }

      .empty-state i {
        font-size: 3rem;
      }
    }

    @media (max-width: 576px) {
      .schedule-table thead th {
        font-size: 0.7rem;
        padding: 0.5rem;
      }

      .schedule-table tbody td {
        padding: 0.5rem;
        font-size: 0.8rem;
      }
    }
  </style>

</body>
</html>