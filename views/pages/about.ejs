<%- include('../partials/head') %>
<body class="about-page">
  <%- include('../partials/navbar') %>
  <br><br>

  <!-- Company Header Section -->
  <section class="company-header">
    <div class="container">
      <div class="row">
        <div class="col-12 text-center">
          <h1 class="mb-3">About StudyCraft</h1>
          <p class="lead">A portfolio project by Mahendra Harijan - Demonstrating full-stack development skills</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Details Section -->
  <div class="container">
    <div class="row mb-4">
      <div class="col-12">
        <a href="/" class="back-to-home">
          <i class="fas fa-arrow-left"></i> Back to Home
        </a>
      </div>
    </div>

    <!-- Project Information -->
    <div class="row">
      <div class="col-lg-8 offset-lg-2">
        <!-- Project Overview -->
        <div class="card company-card mb-5">
          <div class="card-header">
            <h3 class="mb-0"><i class="fas fa-code me-2"></i>Project Overview</h3>
          </div>
          <div class="card-body">
            <p class="mb-4"><strong>StudyCraft</strong> is a comprehensive full-stack web application developed as a portfolio project by <strong>Mahendra Harijan</strong> to help engineering students manage their academic life efficiently.</p>
            
            <div class="row">
              <div class="col-md-6">
                <h5><i class="fas fa-laptop-code text-primary me-2"></i>Technical Stack</h5>
                <ul>
                  <li>Node.js & Express.js</li>
                  <li>MongoDB with Mongoose</li>
                  <li>EJS Templating</li>
                  <li>Bootstrap 5</li>
                  <li>JWT Authentication</li>
                  <li>Cloudinary Integration</li>
                </ul>
              </div>
              <div class="col-md-6">
                <h5><i class="fas fa-feather-alt text-primary me-2"></i>Key Features</h5>
                <ul>
                  <li>Smart Class Scheduler</li>
                  <li>Task & Assignment Tracker</li>
                  <li>Engineering Calculators</li>
                  <li>Revision Hub</li>
                  <li>Secure Authentication</li>
                  <li>Push Notifications</li>
                </ul>
              </div>
            </div>
            
            <!-- Development Timeline -->
            <div class="mt-4">
              <h6><i class="fas fa-calendar-alt text-primary me-2"></i>Development Timeline</h6>
              <p class="mb-0">January 2025 to February 2025</p>
            </div>
          </div>
        </div>

        <!-- Developer Information -->
        <div class="founder-section text-center">
          <div class="profile-img-small-container mb-3">
            <div class="profile-img-wrapper-small">
                  <img src="/public/image/photo.jpg" 
                   alt="Mahendra Harijan" 
                   class="profile-img-small"
                   loading="lazy">
            </div>
          </div>
          <h3>Mahendra Harijan</h3>
          <p class="text-muted">Full Stack Developer & Project Creator</p>
          <p>This project was independently developed to showcase web development skills and understanding of modern full-stack technologies. Based in Gandhinagar, I'm passionate about creating tools that make students' lives easier.</p>
          
          <div class="mt-4">
            <a href="https://github.com/mahendra201118" class="btn btn-outline-primary me-2" target="_blank">
              <i class="fab fa-github me-1"></i> GitHub
            </a>
            <a href="https://linkedin.com/in/mahendra-harijan" class="btn btn-outline-primary me-2" target="_blank">
              <i class="fab fa-linkedin me-1"></i> LinkedIn
            </a>
            <a href="mailto:mahendra201118@gmail.com" class="btn btn-outline-primary">
              <i class="fas fa-envelope me-1"></i> Contact
            </a>
          </div>
        </div>

        <!-- Project Details Card -->
        <div class="card company-card mt-5">
          <div class="card-header">
            <h3 class="mb-0"><i class="fas fa-info-circle me-2"></i>Project Details</h3>
          </div>
          <div class="card-body">
            <!-- Dynamic Links -->
            <div class="company-detail">
              <div class="detail-label">Source Code:</div>
              <div class="detail-value">
                <a href="https://github.com/mahendra201118/studycraft" target="_blank" class="text-decoration-none">
                  github.com/mahendra201118/studycraft
                </a>
              </div>
            </div>

            <div class="company-detail">
              <div class="detail-label">Developer Portfolio:</div>
              <div class="detail-value">
                <a href="https://mahendra-dev.vercel.app" target="_blank" class="text-decoration-none">
                  mahendra-dev.vercel.app
                </a>
              </div>
            </div>

            <div class="company-detail">
              <div class="detail-label">Project Status:</div>
              <div class="detail-value">
                <span class="badge bg-success">Active Development</span>
              </div>
            </div>

            <!-- Disclaimer -->
            <div class="alert alert-warning mt-4">
              <i class="fas fa-exclamation-triangle me-2"></i>
              <strong>Note:</strong> This is a portfolio project created for demonstration purposes. While fully functional, it's intended to showcase development skills rather than commercial use.
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-section mt-5">
          <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white">
              <h3 class="mb-0">
                <i class="fas fa-envelope me-2"></i>
                Contact Developer
              </h3>
              <p class="mb-0 small opacity-75">Get in touch for feedback or opportunities</p>
            </div>
            
            <div class="card-body p-4">
              <!-- Form Container -->
              <div id="form-container">
                <div id="contact-flash" class="alert <%= contactFlash ? ('alert-' + contactFlash.type) : '' %> <%= contactFlash ? '' : 'd-none' %>" role="alert">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <span id="contact-flash-text"><%= contactFlash ? contactFlash.message : '' %></span>
                    <button type="button" class="btn-close" aria-label="Close" id="contact-flash-close"></button>
                  </div>
                  <div class="mt-2 d-none" id="contact-flash-actions">
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="contact-flash-action-btn"></button>
                  </div>
                </div>

                <!-- Contact Form -->
                <form id="contact-form" novalidate>
                  <div class="row g-3">
                    <!-- Name Field -->
                    <div class="col-md-6">
                      <label for="name" class="form-label">
                        <i class="fas fa-user me-1"></i> Full Name *
                      </label>
                      <input type="text" 
                             class="form-control" 
                             id="name" 
                             name="name" 
                             placeholder="Enter your full name"
                             required>
                      <div class="invalid-feedback" id="name-error">
                        Please enter your name (minimum 2 characters)
                      </div>
                    </div>

                    <!-- Email Field -->
                    <div class="col-md-6">
                      <label for="email" class="form-label">
                        <i class="fas fa-envelope me-1"></i> Email Address *
                      </label>
                      <input type="email" 
                             class="form-control" 
                             id="email" 
                             name="email" 
                             placeholder="your.email@example.com"
                             required>
                      <div class="invalid-feedback" id="email-error">
                        Please enter a valid email address
                      </div>
                    </div>

                    <!-- Subject Field -->
                    <div class="col-12">
                      <label for="subject" class="form-label">
                        <i class="fas fa-tag me-1"></i> Subject *
                      </label>
                      <input type="text" 
                             class="form-control" 
                             id="subject" 
                             name="subject" 
                             placeholder="What is this regarding?"
                             required>
                      <div class="invalid-feedback" id="subject-error">
                        Please enter a subject (minimum 3 characters)
                      </div>
                    </div>

                    <!-- Message Field -->
                    <div class="col-12">
                      <label for="message" class="form-label">
                        <i class="fas fa-comment-dots me-1"></i> Message *
                      </label>
                      <textarea class="form-control" 
                                id="message" 
                                name="message" 
                                rows="5" 
                                placeholder="Type your message here..."
                                required></textarea>
                      <div class="invalid-feedback" id="message-error">
                        Please enter a message (minimum 10 characters)
                      </div>
                      <div class="form-text">
                        <span id="char-count">0</span> / 500 characters
                      </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="col-12">
                      <button type="submit" 
                              class="btn btn-primary btn-lg w-100 py-3" 
                              id="submit-btn">
                        <span class="submit-text">
                          <i class="fas fa-paper-plane me-2"></i>
                          Send Message
                        </span>
                        <span class="loading-spinner d-none">
                          <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                          Processing...
                        </span>
                      </button>
                    </div>

                    <!-- Privacy Note -->
                    <div class="col-12">
                      <div class="form-text text-center small">
                        <i class="fas fa-shield-alt me-1"></i>
                        Your information is secure. I'll only use it to respond to your message.
                      </div>
                      <div class="text-center mt-2">
                        <a href="mailto:mahendra201118@gmail.com" class="btn btn-outline-secondary btn-sm">
                          <i class="fas fa-envelope me-1"></i> Email Directly
                        </a>
                      </div>
                    </div>
                  </div>
                </form>

                <div id="contact-success-panel" class="d-none contact-success-panel text-center mt-3">
                  <div class="success-icon-wrap mx-auto mb-3">
                    <i class="fas fa-check"></i>
                  </div>
                  <h4 class="mb-2">Message Sent Successfully</h4>
                  <p class="text-muted mb-3">
                    Thank you for reaching out. Your message has been delivered and I’ll get back to you within 24 hours.
                  </p>
                  <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <button type="button" class="btn btn-primary" id="contact-send-another-btn">
                      <i class="fas fa-plus me-1"></i> Send Another Message
                    </button>
                    <a href="/" class="btn btn-outline-secondary">
                      <i class="fas fa-home me-1"></i> Back to Home
                    </a>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="card-footer bg-light">
              <div class="row align-items-center">
                <div class="col-md-6">
                  <small class="text-muted">
                    <i class="fas fa-clock me-1"></i>
                    Typically responds within 24 hours
                  </small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
  <script src="/public/js/about-emailjs.js"></script>

  <style>
    /* About Page Specific Styles */
    .about-page {
      background: linear-gradient(135deg, #f5f7fa 0%, #e9ecf5 100%);
      min-height: 100vh;
    }

    body.dark-mode .about-page {
      background: linear-gradient(135deg, #1a1c24 0%, #0f1117 100%);
    }

    /* Company Header */
    .company-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 4rem 0;
      margin-bottom: 2rem;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .company-header::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.1"><path d="M10 50 Q 30 30, 50 50 T 90 50" stroke="white" fill="none" stroke-width="2"/><circle cx="20" cy="20" r="3" fill="white"/><circle cx="80" cy="80" r="3" fill="white"/></svg>');
      background-size: 100px 100px;
      opacity: 0.1;
    }

    .company-header h1 {
      font-size: 2.8rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .company-header .lead {
      font-size: 1.2rem;
      opacity: 0.95;
      max-width: 700px;
      margin: 0 auto;
    }

    /* Back to Home Link */
    .back-to-home {
      display: inline-flex;
      align-items: center;
      color: #667eea;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.3s;
    }

    .back-to-home:hover {
      transform: translateX(-5px);
      color: #764ba2;
    }

    .back-to-home i {
      margin-right: 0.5rem;
    }

    /* Company Cards */
    .company-card {
      border: none;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
    }

    .company-card .card-header {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border: none;
      padding: 1.2rem 1.5rem;
    }

    .company-card .card-header h3 {
      font-size: 1.3rem;
      font-weight: 600;
    }

    .company-card .card-body {
      padding: 2rem;
    }

    .company-card ul {
      list-style: none;
      padding-left: 0;
    }

    .company-card ul li {
      padding: 0.3rem 0;
      position: relative;
      padding-left: 1.5rem;
    }

    .company-card ul li:before {
      content: "✓";
      color: #667eea;
      font-weight: 600;
      position: absolute;
      left: 0;
    }

    /* Founder Section */
    .founder-section {
      background: white;
      border-radius: 16px;
      padding: 2.5rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
    }

    body.dark-mode .founder-section {
      background: #2d2d3f;
    }

    .profile-img-small-container {
      display: flex;
      justify-content: center;
    }

    .profile-img-wrapper-small {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      overflow: hidden;
      border: 4px solid #667eea;
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }

    .profile-img-small {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .founder-section h3 {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 0.3rem;
    }

    .founder-section .text-muted {
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .founder-section p {
      color: #666;
      line-height: 1.6;
      max-width: 600px;
      margin: 0 auto;
    }

    body.dark-mode .founder-section p {
      color: #aaa;
    }

    /* Company Details */
    .company-detail {
      display: flex;
      padding: 0.8rem 0;
      border-bottom: 1px solid #e9ecef;
    }

    .company-detail:last-child {
      border-bottom: none;
    }

    .detail-label {
      width: 120px;
      font-weight: 600;
      color: #555;
    }

    body.dark-mode .detail-label {
      color: #ccc;
    }

    .detail-value {
      flex: 1;
      color: #667eea;
    }

    .detail-value a {
      color: #667eea;
      transition: all 0.3s;
    }

    .detail-value a:hover {
      color: #764ba2;
      text-decoration: underline !important;
    }

    /* Contact Section */
    .contact-section {
      margin-bottom: 3rem;
    }

    .contact-section .card {
      border-radius: 16px;
      overflow: hidden;
    }

    .contact-section .card-header {
      background: linear-gradient(135deg, #667eea, #764ba2);
      padding: 1.5rem;
    }

    .contact-section .form-control {
      border: 2px solid #e9ecef;
      border-radius: 10px;
      padding: 0.8rem;
      transition: all 0.3s;
    }

    .contact-section .form-control:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .contact-section .btn-primary {
      background: linear-gradient(135deg, #667eea, #764ba2);
      border: none;
      font-weight: 600;
      transition: all 0.3s;
    }

    .contact-section .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }

    .contact-section .btn-outline-primary {
      border-color: #667eea;
      color: #667eea;
    }

    .contact-section .btn-outline-primary:hover {
      background: #667eea;
      color: white;
    }

    /* Alert Styles */
    .alert-success, .alert-danger {
      border-radius: 12px;
      padding: 1.2rem;
    }

    .alert-success {
      background: #d4edda;
      border-color: #c3e6cb;
    }

    .alert-danger {
      background: #f8d7da;
      border-color: #f5c6cb;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .company-header {
        padding: 3rem 0;
      }

      .company-header h1 {
        font-size: 2rem;
      }

      .company-header .lead {
        font-size: 1rem;
      }

      .company-card .card-body {
        padding: 1.5rem;
      }

      .founder-section {
        padding: 1.5rem;
      }

      .founder-section h3 {
        font-size: 1.5rem;
      }

      .profile-img-wrapper-small {
        width: 100px;
        height: 100px;
      }

      .company-detail {
        flex-direction: column;
      }

      .detail-label {
        width: 100%;
        margin-bottom: 0.3rem;
      }

      .contact-section .card-header h3 {
        font-size: 1.2rem;
      }
    }

    /* Dark Mode Adjustments */
    body.dark-mode .company-card,
    body.dark-mode .founder-section {
      background: #2d2d3f;
    }

    body.dark-mode .company-card .card-body p,
    body.dark-mode .company-card li {
      color: #e0e0e0;
    }

    body.dark-mode .company-detail {
      border-bottom-color: #3a3a4a;
    }

    body.dark-mode .detail-label {
      color: #aaa;
    }

    body.dark-mode .contact-section .form-control {
      background: #2d2d3f;
      border-color: #3a3a4a;
      color: white;
    }

    body.dark-mode .contact-section .form-control::placeholder {
      color: #666;
    }

    body.dark-mode .card-footer {
      background: #2d2d3f !important;
      color: #e0e0e0;
    }

    body.dark-mode .text-muted {
      color: #aaa !important;
    }

    .contact-success-panel {
      border: 1px solid #d1fae5;
      background: #f0fdf4;
      border-radius: 14px;
      padding: 1.5rem;
    }

    .success-icon-wrap {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #22c55e;
      color: #fff;
      display: grid;
      place-items: center;
      font-size: 1.4rem;
      box-shadow: 0 8px 18px rgba(34, 197, 94, 0.28);
    }

    body.dark-mode .contact-success-panel {
      border-color: #166534;
      background: #0f2d1c;
    }
  </style>

</body>
</html>