<%- include('../partials/head') %>
<body class="landing-page">
  <%- include('../partials/navbar') %>

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="row min-vh-100 align-items-center">
        <div class="col-lg-7" data-aos="fade-right">
          <!-- Main Heading -->
          <h1 class="hero-title">
            Craft Your Academic Success with 
            <span class="gradient-text">StudyCraft</span>
          </h1>
          
          <!-- Description -->
          <p class="hero-description">
            The all-in-one platform for engineering students to schedule classes, 
            manage tasks, perform calculations, and organize revision materials.
          </p>
          
          <!-- CTA Buttons -->
          <div class="hero-cta d-flex flex-wrap gap-3 mt-4">
            <a href="/signup" class="btn btn-primary btn-lg px-4">
              Get Started Free
            </a>
            <a href="/dashboard" class="btn btn-outline-primary btn-lg px-4">
              Live Demo
            </a>
          </div>
        </div>
        
        <div class="col-lg-5" data-aos="fade-left">
          <!-- Feature Preview Card -->
          <div class="preview-card">
            <div class="preview-item">
              <div class="preview-icon">
                <i class="fas fa-calendar-check"></i>
              </div>
              <div class="preview-content">
                <h4>Class Scheduler</h4>
                <p>Organize your timetable with ease</p>
              </div>
            </div>
            
            <div class="preview-item">
              <div class="preview-icon">
                <i class="fas fa-tasks"></i>
              </div>
              <div class="preview-content">
                <h4>Task Manager</h4>
                <p>Track assignments and deadlines</p>
              </div>
            </div>
            
            <div class="preview-item">
              <div class="preview-icon">
                <i class="fas fa-calculator"></i>
              </div>
              <div class="preview-content">
                <h4>Calculators</h4>
                <p>Scientific, matrix & crypto tools</p>
              </div>
            </div>
            
            <div class="preview-item">
              <div class="preview-icon">
                <i class="fas fa-book-open"></i>
              </div>
              <div class="preview-content">
                <h4>Revision Hub</h4>
                <p>Keep notes and formulas organized</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features-section py-5" id="features">
    <div class="container py-5">
      <div class="text-center mb-5">
        <h2 class="section-title">Everything You Need in One Place</h2>
        <p class="section-subtitle">Powerful tools designed for engineering students</p>
      </div>
      
      <div class="row g-4">
        <div class="col-md-6 col-lg-4">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-calendar-alt"></i>
            </div>
            <h3>Class Scheduler</h3>
            <p>Smart timetable with clash detection and weekly repeats. Get reminders before your classes start.</p>
          </div>
        </div>
        
        <div class="col-md-6 col-lg-4">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-tasks"></i>
            </div>
            <h3>Task Management</h3>
            <p>Track assignments with priority levels and deadlines. Never miss an important submission.</p>
          </div>
        </div>
        
        <div class="col-md-6 col-lg-4">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-calculator"></i>
            </div>
            <h3>Engineering Calculators</h3>
            <p>Scientific, matrix operations, and cryptographic tools for all your calculation needs.</p>
          </div>
        </div>
        
        <div class="col-md-6 col-lg-4">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-book-open"></i>
            </div>
            <h3>Revision Hub</h3>
            <p>Organize notes, formulas, and study materials in one central location.</p>
          </div>
        </div>
        
        <div class="col-md-6 col-lg-4">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-bell"></i>
            </div>
            <h3>Smart Reminders</h3>
            <p>Get notified about upcoming classes and pending tasks before it's too late.</p>
          </div>
        </div>
        
        <div class="col-md-6 col-lg-4">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <h3>Progress Dashboard</h3>
            <p>View your daily schedule, upcoming tasks, and activity at a glance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="how-it-works py-5">
    <div class="container py-4">
      <div class="text-center mb-5">
        <h2 class="section-title">Simple 3-Step Process</h2>
        <p class="section-subtitle">Get started in minutes</p>
      </div>
      
      <div class="row g-4">
        <div class="col-md-4">
          <div class="step-card">
            <div class="step-number">1</div>
            <h4>Create Account</h4>
            <p>Sign up with your email address. It's completely free.</p>
          </div>
        </div>
        
        <div class="col-md-4">
          <div class="step-card">
            <div class="step-number">2</div>
            <h4>Add Your Classes</h4>
            <p>Input your timetable with subject, time, and venue.</p>
          </div>
        </div>
        
        <div class="col-md-4">
          <div class="step-card">
            <div class="step-number">3</div>
            <h4>Start Using</h4>
            <p>Manage tasks, use calculators, and organize revision.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section py-5">
    <div class="container py-4">
      <div class="cta-card text-center">
        <h2 class="cta-title">Ready to get started?</h2>
        <p class="cta-text">Join thousands of engineering students using StudyCraft</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
          <a href="/signup" class="btn btn-primary btn-lg px-5">
            Create Free Account
          </a>
        </div>
        <p class="mt-3 small text-white-50">No credit card required • Free forever</p>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>

  <!-- Add AOS Animation Library -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script>
    AOS.init({
      duration: 800,
      once: true
    });
  </script>

  <style>
    /* Reset and Base Styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      overflow-x: hidden;
    }

    .landing-page {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    /* Hero Section */
    .hero-section {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      color: white;
    }

    .hero-title {
      font-size: 3.2rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }

    .gradient-text {
      background: linear-gradient(135deg, #FFD700, #FFA500);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-description {
      font-size: 1.2rem;
      opacity: 0.9;
      max-width: 550px;
      line-height: 1.6;
    }

    .hero-cta .btn-primary {
      background: white;
      color: #667eea;
      border: none;
      font-weight: 600;
    }

    .hero-cta .btn-primary:hover {
      background: #f8f9fa;
      transform: translateY(-2px);
    }

    .hero-cta .btn-outline-primary {
      background: transparent;
      color: white;
      border: 2px solid white;
      font-weight: 600;
    }

    .hero-cta .btn-outline-primary:hover {
      background: white;
      color: #667eea;
      transform: translateY(-2px);
    }

    /* Preview Card */
    .preview-card {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 24px;
      padding: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .preview-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .preview-item:last-child {
      border-bottom: none;
    }

    .preview-icon {
      width: 48px;
      height: 48px;
      background: rgba(255, 255, 255, 0.15);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .preview-content h4 {
      font-size: 1rem;
      margin-bottom: 0.2rem;
      font-weight: 600;
    }

    .preview-content p {
      font-size: 0.85rem;
      opacity: 0.8;
      margin: 0;
    }

    /* Features Section */
    .features-section {
      background: white;
    }

    body.dark-mode .features-section {
      background: #1a1c24;
    }

    .section-title {
      font-size: 2.2rem;
      font-weight: 700;
      color: #333;
      margin-bottom: 0.5rem;
    }

    body.dark-mode .section-title {
      color: #fff;
    }

    .section-subtitle {
      font-size: 1.1rem;
      color: #666;
    }

    body.dark-mode .section-subtitle {
      color: #aaa;
    }

    .feature-card {
      background: #f8f9fa;
      border-radius: 16px;
      padding: 2rem;
      height: 100%;
      transition: transform 0.3s;
      border: 1px solid #e9ecef;
    }

    body.dark-mode .feature-card {
      background: #2d2d3f;
      border-color: #3a3a4a;
    }

    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .feature-icon {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      color: white;
      margin-bottom: 1.5rem;
    }

    .feature-card h3 {
      font-size: 1.3rem;
      margin-bottom: 0.8rem;
      color: #333;
    }

    body.dark-mode .feature-card h3 {
      color: #fff;
    }

    .feature-card p {
      color: #666;
      line-height: 1.6;
      margin: 0;
    }

    body.dark-mode .feature-card p {
      color: #aaa;
    }

    /* How It Works Section */
    .how-it-works {
      background: #f8f9fa;
    }

    body.dark-mode .how-it-works {
      background: #1e1e2f;
    }

    .step-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
      height: 100%;
      box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    body.dark-mode .step-card {
      background: #2d2d3f;
    }

    .step-number {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      margin: 0 auto 1.5rem;
    }

    .step-card h4 {
      font-size: 1.2rem;
      margin-bottom: 0.8rem;
      color: #333;
    }

    body.dark-mode .step-card h4 {
      color: #fff;
    }

    .step-card p {
      color: #666;
      margin: 0;
      line-height: 1.5;
    }

    body.dark-mode .step-card p {
      color: #aaa;
    }

    /* CTA Section */
    .cta-section {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
    }

    .cta-card {
      max-width: 600px;
      margin: 0 auto;
    }

    .cta-title {
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .cta-text {
      font-size: 1.1rem;
      opacity: 0.9;
      margin-bottom: 2rem;
    }

    .cta-card .btn-primary {
      background: white;
      color: #667eea;
      border: none;
      font-weight: 600;
    }

    .cta-card .btn-primary:hover {
      background: #f8f9fa;
      transform: translateY(-2px);
    }

    .text-white-50 {
      color: rgba(255, 255, 255, 0.5);
    }

    /* Responsive Design */
    @media (max-width: 992px) {
      .hero-title {
        font-size: 2.5rem;
      }
      
      .hero-section {
        padding: 4rem 0;
        text-align: center;
      }
      
      .hero-description {
        margin: 0 auto;
      }
      
      .hero-cta {
        justify-content: center;
      }
      
      .preview-card {
        margin-top: 2rem;
      }
    }

    @media (max-width: 768px) {
      .section-title {
        font-size: 1.8rem;
      }
      
      .hero-title {
        font-size: 2rem;
      }
      
      .feature-card {
        padding: 1.5rem;
      }
      
      .cta-title {
        font-size: 1.8rem;
      }
    }

    /* Utility Classes */
    .btn-lg {
      padding: 0.8rem 2rem;
      font-size: 1rem;
    }
  </style>
</body>
</html>